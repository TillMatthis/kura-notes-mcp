  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kura-notes",
    "claude"
  ],
  "author": "",
  "license": "Elastic-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
