{
  "name": "kura-mcp-client",
  "version": "0.1.0",
  "description": "MCP client for KURA Notes API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kura-mcp-client": "dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
